# Instructions :
# 1. Copier ce fichier en "application-secrets.yml" (dans ce même dossier resources).
# 2. Remplacer la valeur ci-dessous par votre clé Google Gemini.
# 3. Ne jamais committer application-secrets.yml (déjà listé dans .gitignore du module ai-service).
#
# Tu peux envoyer le projet à quelqu’un : elle copie ce .example → application-secrets.yml sur SON PC
# avec SA propre clé, sans la mettre dans Git.

gemini:
  api:
    key: "REMPLACEZ_PAR_VOTRE_CLE_GEMINI"
